alias v="fd --type f --hidden --exclude .git | fzf-tmux -p --reverse --preview 'bat --color=always --line-range :50 {}' | xargs nvim"

# Terminal 
alias c="clear"
alias x="exit"
alias e="code -n ~/ ~/.zshrc ~/.aliases ~/.colors ~/.hooks"
alias r="source ~/.zshrc"

# History
alias h="history -10" # last 10 history commands
alias hc="history -c" # clear history
alias hg="history | grep " # +command

# Easier navigation
alias ..="cd .."
alias ...="cd ../.."
alias .3="cd ../../.."
alias .4="cd ../../../.."

# Git 
alias gs='git status'

# Always enable colored `grep` output
# Note: `GREP_OPTIONS="--color=auto"` is deprecated, hence the alias usage.
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias sgrep='grep -R -n -H -C 5 --exclude-dir={.git,.svn,CVS} '

# ls: eza with icons and git status
alias ls='eza --group-directories-first --icons'
alias ll='eza -lh --group-directories-first --icons --git'
alias la='eza -lah --group-directories-first --icons --git'
alias tree='eza --tree --icons'


# mkdir: create parent directories
alias mkdir="mkdir -pv"

# bat (better cat)
alias cat='bat --paging=never'
alias catp='bat'

# tldr
alias tl='tldr'

# Git
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gpl='git pull'
alias gl='git log --oneline --graph --decorate'
alias gd='git diff'
alias gco='git checkout'
alias gcm='git checkout main 2>/dev/null || git checkout master'
alias grb='git rebase'
alias gst='git stash'
alias gstp='git stash pop'

# Python
alias py='python3'
alias pip='pip3'

# Dotfiles
alias dots='cd ~/.dotfiles'
alias ez='nvim ~/.dotfiles/zsh/.zsh_alias ~/.dotfiles/zsh/.zsh_functions'

# Network
alias ports='lsof -iTCP -sTCP:LISTEN -n -P'


















